# Example environment file for linux-server
# Copy this to .env and adjust the values. Do NOT commit your real .env with secrets.

# Image versions (configurable)
VSCODE_IMAGE=ghcr.io/coder/code-server:latest
NGINX_IMAGE=nginx:1.27-alpine
PIHOLE_IMAGE=pihole/pihole:latest
DASHY_IMAGE=lissy93/dashy:latest
DOCKERPROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
PORTAINER_IMAGE=portainer/portainer-ce:lts
GLANCES_IMAGE=nicolargo/glances:latest-full

# Databases / app images
MYSQL_IMAGE=mysql:8.0
NEXTCLOUD_IMAGE=nextcloud:latest
JELLYFIN_IMAGE=jellyfin/jellyfin:latest
QBITTORRENT_IMAGE=linuxserver/qbittorrent:latest
FILEBROWSER_IMAGE=filebrowser/filebrowser:latest

# Immich version (kept for backwards-compatibility)
IMMICH_VERSION=v2.5.5

# Immich storage paths
UPLOAD_LOCATION=/mnt/mediahdd/immich
IMMICH_MODEL_CACHE=/mnt/mediahdd/immich/model-cache

# Immich database
DB_PASSWORD=changeme
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/home/docker-volumes/immich/postgres

# Access stack images
TAILSCALE_IMAGE=tailscale/tailscale:latest
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
TWINGATE_IMAGE=twingate/connector:1

# Example placeholders for other env vars (secrets should go into your real .env and be kept private)
# VSCODE_PASSWORD=changeme
# MYSQL_ROOT_PASSWORD=changeme
# NEXTCLOUD_DB_PASSWORD=changeme
# PIHOLE_WEBPASSWORD=changeme

# End of example
