# Example environment file for linux-server
# Copy this to .env and adjust the values. Do NOT commit your real .env with secrets.

# Image versions (configurable)
VSCODE_IMAGE=ghcr.io/coder/code-server:latest
NGINX_IMAGE=nginx:1.27-alpine
PIHOLE_IMAGE=pihole/pihole:latest
DASHY_IMAGE=lissy93/dashy:latest
DOCKERPROXY_IMAGE=tecnativa/docker-socket-proxy:0.3.0
PORTAINER_IMAGE=portainer/portainer-ce:lts
GLANCES_IMAGE=nicolargo/glances:latest-full

# Databases / app images
MYSQL_IMAGE=mysql:8.0
NEXTCLOUD_IMAGE=nextcloud:latest
JELLYFIN_IMAGE=jellyfin/jellyfin:latest
QBITTORRENT_IMAGE=linuxserver/qbittorrent:latest
FILEBROWSER_IMAGE=filebrowser/filebrowser:latest

# Immich version (kept for backwards-compatibility)
IMMICH_VERSION=v2.5.5

# Immich storage paths
UPLOAD_LOCATION=/mnt/mediahdd/immich
IMMICH_MODEL_CACHE=/mnt/mediahdd/immich/model-cache

# Immich database
DB_PASSWORD=changeme
DB_USERNAME=immich
DB_DATABASE_NAME=immich
DB_DATA_LOCATION=/home/docker-volumes/immich/postgres

# Access stack images
TAILSCALE_IMAGE=tailscale/tailscale:latest
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
TWINGATE_IMAGE=twingate/connector:1

# Example placeholders for other env vars (secrets should go into your real .env and be kept private)


# You can find documentation for all the supported env variables at https://immich.app/docs/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=/mnt/mediahdd/immich

# The location where your database files are stored. Network shares are not supported for the database
DB_DATA_LOCATION=/home/docker-volumes/immich/postgres

# To set a timezone, uncomment the next line and change Etc/UTC to a TZ identifier from this list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
# TZ=Etc/UTC

# The Immich version to use. You can pin this to a specific version like "v1.71.0"
IMMICH_VERSION=v2.7.5

# Connection secret for postgres. You should change it to a random password
# Please use only the characters `A-Za-z0-9`, without special characters or spaces
DB_PASSWORD=immich1234

# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

IMMICH_ROOT=/mnt/mediahdd/immich
IMMICH_MODEL_CACHE=/mnt/mediahdd/immich/model-cache

JELLYFIN_ROOT=/mnt/mediahdd/jellyfin
QBITTORRENT_DOWNLOADS_ROOT=/mnt/mediahdd/downloads

# VsCode Password
VSCODE_PASSWORD=code1234
VSCODE_WORKSPACE=/home/jayasuriyan/vscode

TIMEZONE=Asia/Kolkata
BASE_DOMAIN=home.local
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

MYSQL_ROOT_PASSWORD=mysql1234
NEXTCLOUD_DB_PASSWORD=nextcloud1234
BOOKSTACK_DB_PASSWORD=bookstack_admin
NEXTCLOUD_TRUSTED_DOMAINS=mycloud.home.local nextcloud.home.local home.local

#PiHole IP
PIHOLE_IP=10.10.2.201
PIHOLE_WEBPASSWORD=pihole1234

SERVER_IP=10.10.2.200
MACVLAN_SUBNET=10.10.2.0/24
MACVLAN_GATEWAY=10.10.2.1
MACVLAN_PARENT=eno2

#Twin Gate
TWINGATE_NETWORK=
TWINGATE_LABEL_HOSTNAME=
TWINGATE_ACCESS_TOKEN=

# Tailscale Funneling
TS_AUTH_KEY=

# Optional override keys per sidecar (falls back to TS_AUTH_KEY if unset)
TS_HOSTNAME_N8N=n8n
TS_HOSTNAME_OPENCLAW=openclaw
TS_TUNNEL=https://n8n-server.tail83b140.ts.net/